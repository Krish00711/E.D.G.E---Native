# Frontend Environment Configuration Template

# API Configuration
VITE_API_URL=http://localhost:5000
VITE_ML_SERVICE_URL=http://localhost:5001

# App Environment
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG=true

# DO NOT ADD PASSWORDS, API KEYS, OR TOKENS HERE!
# Those belong in .env.local which is in .gitignore
